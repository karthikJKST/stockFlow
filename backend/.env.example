# StockFlow Backend Environment Variables
# Copy this file to .env and fill in your values

# Finnhub API Key (optional - uses simulated data if not set)
# Get a free API key at https://finnhub.io/
FINNHUB_API_KEY=

# JWT Secret (REQUIRED for production - change this to a strong secret!)
# Default dev value is used if not set
JWT_SECRET=

# Database password (for PostgreSQL mode)
DB_PASSWORD=stockflow
