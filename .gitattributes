# Auto-detect text files and normalize line endings
* text=auto

# Source code
*.java text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.html text eol=lf

# Config files
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.properties text eol=lf

# Shell scripts
*.sh text eol=lf
*.bat text eol=crlf
*.cmd text eol=crlf

# Documentation
*.md text eol=lf
*.txt text eol=lf

# Docker
Dockerfile text eol=lf
Dockerfile.* text eol=lf

# Maven wrapper
mvnw text eol=lf
mvnw.cmd text eol=crlf

# Environment files
.env text eol=lf
.env.* text eol=lf

# Git
.gitignore text eol=lf
.gitattributes text eol=lf
.gitmodules text eol=lf

# Binary files
*.jar binary
*.png binary
*.jpg binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.eot binary
*.ttf binary
