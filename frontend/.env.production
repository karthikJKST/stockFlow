# StockFlow Frontend Production Environment Variables
# These values are used during production builds.
# May be overridden by Vercel environment variables.

# Backend API URL
VITE_API_URL=https://stockflow-rr2k.onrender.com/api

# WebSocket URL (SockJS: use https://, not wss:// — SockJS handles protocol upgrade internally)
VITE_WS_URL=https://stockflow-rr2k.onrender.com/ws
